<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudyMateProject.Components.CalculatorComponent"
             x:Name="CalculatorRoot">

    <!-- Основной компонент калькулятора - переиспользуемый в разных местах -->
    <Grid RowDefinitions="Auto,*" 
          BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">

        <!-- Дисплей калькулятора -->
        <Border Grid.Row="0" 
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                StrokeThickness="1"
                Margin="8,8,8,4">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>

            <Grid RowDefinitions="Auto,Auto,*" Padding="16">

                <!-- История операций (верхняя строка) -->
                <Label Grid.Row="0"
                       Text="{Binding HistoryText}"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                       HorizontalOptions="End"
                       VerticalOptions="Center"
                       IsVisible="{Binding HistoryText, Converter={StaticResource IsStringNotNullOrEmptyConverter}}"
                       LineBreakMode="TailTruncation"/>

                <!-- Основной результат -->
                <Label Grid.Row="1"
                       Text="{Binding DisplayText}"
                       FontSize="{Binding FontSize, Source={x:Reference CalculatorRoot}}"
                       FontFamily="Consolas"
                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                       HorizontalOptions="End"
                       VerticalOptions="Center"
                       LineBreakMode="HeadTruncation"
                       Margin="0,8,0,0"/>

                <!-- Индикатор загрузки -->
                <ActivityIndicator Grid.Row="2"
                                   IsVisible="{Binding IsCalculating}"
                                   IsRunning="{Binding IsCalculating}"
                                   Color="{StaticResource Primary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HeightRequest="24"/>

                <!-- Сообщение об ошибке -->
                <Label Grid.Row="2"
                       Text="{Binding ErrorMessage}"
                       FontSize="12"
                       TextColor="{StaticResource Danger}"
                       HorizontalOptions="End"
                       VerticalOptions="End"
                       IsVisible="{Binding HasError}"
                       LineBreakMode="WordWrap"
                       MaxLines="2"/>
            </Grid>
        </Border>

        <!-- Кнопки калькулятора -->
        <ScrollView Grid.Row="1" Margin="8,4,8,8">
            <Grid x:Name="ButtonsContainer">

                <!-- Научный режим -->
                <Grid x:Name="ScientificButtonsGrid"
                      IsVisible="{Binding ShowScientificFunctions}"
                      RowDefinitions="Auto,Auto"
                      ColumnDefinitions="*,*,*,*,*,*"
                      RowSpacing="8"
                      ColumnSpacing="8"
                      Margin="0,0,0,8">

                    <!-- Первая строка научных функций -->
                    <Button Grid.Row="0" Grid.Column="0" Text="sin" 
                            Command="{Binding SinCommand}"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="50"
                            FontSize="14"/>
                    <Button Grid.Row="0" Grid.Column="1" Text="cos" 
                            Command="{Binding CosCommand}"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="50"
                            FontSize="14"/>
                    <Button Grid.Row="0" Grid.Column="2" Text="tan" 
                            Command="{Binding TanCommand}"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="50"
                            FontSize="14"/>
                    <Button Grid.Row="0" Grid.Column="3" Text="log" 
                            Command="{Binding LogCommand}"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="50"
                            FontSize="14"/>
                    <Button Grid.Row="0" Grid.Column="4" Text="ln" 
                            Command="{Binding LnCommand}"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="50"
                            FontSize="14"/>
                    <Button Grid.Row="0" Grid.Column="5" Text="√" 
                            Command="{Binding SqrtCommand}"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="50"
                            FontSize="14"/>

                    <!-- Вторая строка научных функций -->
                    <Button Grid.Row="1" Grid.Column="0" Text="x²" 
                            Command="{Binding PowerCommand}"
                            CommandParameter="2"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="50"
                            FontSize="14"/>
                    <Button Grid.Row="1" Grid.Column="1" Text="xʸ" 
                            Command="{Binding PowerCommand}"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="50"
                            FontSize="14"/>
                    <Button Grid.Row="1" Grid.Column="2" Text="x!" 
                            Command="{Binding FactorialCommand}"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="50"
                            FontSize="14"/>
                    <Button Grid.Row="1" Grid.Column="3" Text="π" 
                            Command="{Binding PiCommand}"
                            BackgroundColor="{StaticResource Tertiary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="50"
                            FontSize="14"/>
                    <Button Grid.Row="1" Grid.Column="4" Text="e" 
                            Command="{Binding ECommand}"
                            BackgroundColor="{StaticResource Tertiary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="50"
                            FontSize="14"/>
                    <Button Grid.Row="1" Grid.Column="5" Text="°/rad" 
                            Command="{Binding ToggleAngleModeCommand}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                            TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                            HeightRequest="50"
                            FontSize="10"/>
                </Grid>

                <!-- Основные кнопки калькулятора -->
                <Grid x:Name="MainButtonsGrid"
                      RowDefinitions="*,*,*,*,*"
                      ColumnDefinitions="*,*,*,*"
                      RowSpacing="8"
                      ColumnSpacing="8"
                      Margin="0,60,0,0">

                    <!-- Первая строка - Очистка и операторы -->
                    <Button Grid.Row="0" Grid.Column="0" Text="C" 
                            Command="{Binding ClearCommand}"
                            BackgroundColor="{StaticResource Danger}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"
                            FontAttributes="Bold"/>
                    <Button Grid.Row="0" Grid.Column="1" Text="⌫" 
                            Command="{Binding BackspaceCommand}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="0" Grid.Column="2" Text="±" 
                            Command="{Binding OperatorCommand}"
                            CommandParameter="±"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray600}}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="0" Grid.Column="3" Text="÷" 
                            Command="{Binding OperatorCommand}"
                            CommandParameter="÷"
                            BackgroundColor="{StaticResource Warning}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>

                    <!-- Вторая строка - 7,8,9,× -->
                    <Button Grid.Row="1" Grid.Column="0" Text="7" 
                            Command="{Binding NumberCommand}"
                            CommandParameter="7"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="1" Grid.Column="1" Text="8" 
                            Command="{Binding NumberCommand}"
                            CommandParameter="8"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="1" Grid.Column="2" Text="9" 
                            Command="{Binding NumberCommand}"
                            CommandParameter="9"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="1" Grid.Column="3" Text="×" 
                            Command="{Binding OperatorCommand}"
                            CommandParameter="×"
                            BackgroundColor="{StaticResource Warning}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>

                    <!-- Третья строка - 4,5,6,- -->
                    <Button Grid.Row="2" Grid.Column="0" Text="4" 
                            Command="{Binding NumberCommand}"
                            CommandParameter="4"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="2" Grid.Column="1" Text="5" 
                            Command="{Binding NumberCommand}"
                            CommandParameter="5"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="2" Grid.Column="2" Text="6" 
                            Command="{Binding NumberCommand}"
                            CommandParameter="6"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="2" Grid.Column="3" Text="-" 
                            Command="{Binding OperatorCommand}"
                            CommandParameter="-"
                            BackgroundColor="{StaticResource Warning}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>

                    <!-- Четвертая строка - 1,2,3,+ -->
                    <Button Grid.Row="3" Grid.Column="0" Text="1" 
                            Command="{Binding NumberCommand}"
                            CommandParameter="1"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="3" Grid.Column="1" Text="2" 
                            Command="{Binding NumberCommand}"
                            CommandParameter="2"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="3" Grid.Column="2" Text="3" 
                            Command="{Binding NumberCommand}"
                            CommandParameter="3"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="3" Grid.Column="3" Text="+" 
                            Command="{Binding OperatorCommand}"
                            CommandParameter="+"
                            BackgroundColor="{StaticResource Warning}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>

                    <!-- Пятая строка - 0,.,=,(дополнительные кнопки) -->
                    <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="0" 
                            Command="{Binding NumberCommand}"
                            CommandParameter="0"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="4" Grid.Column="2" Text="." 
                            Command="{Binding DecimalCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"/>
                    <Button Grid.Row="4" Grid.Column="3" Text="=" 
                            Command="{Binding CalculateCommand}"
                            BackgroundColor="{StaticResource Success}"
                            TextColor="{StaticResource White}"
                            HeightRequest="60"
                            FontSize="18"
                            FontAttributes="Bold"/>
                </Grid>

                <!-- Дополнительные кнопки для мини-режима -->
                <StackLayout x:Name="MiniModeButtons"
                            Orientation="Horizontal"
                            HorizontalOptions="Center"
                            Spacing="8"
                            Margin="0,8,0,0"
                            IsVisible="{Binding IsMiniMode, Source={x:Reference CalculatorRoot}}">

                    <Button Text="📋 Вставить"
                            Command="{Binding InsertResultCommand}"
                            BackgroundColor="{StaticResource Info}"
                            TextColor="{StaticResource White}"
                            HeightRequest="40"
                            FontSize="12"
                            IsVisible="{Binding ShowInsertButton, Source={x:Reference CalculatorRoot}}"/>

                    <Button Text="🔍 Развернуть"
                            Command="{Binding ExpandToFullCommand}"
                            BackgroundColor="{StaticResource Info}"
                            TextColor="{StaticResource White}"
                            HeightRequest="40"
                            FontSize="12"
                            IsVisible="{Binding ShowExpandButton, Source={x:Reference CalculatorRoot}}"/>

                    <Button Text="📚 История"
                            Command="{Binding ToggleHistoryCommand}"
                            BackgroundColor="{StaticResource Info}"
                            TextColor="{StaticResource White}"
                            HeightRequest="40"
                            FontSize="12"/>
                </StackLayout>

            </Grid>
        </ScrollView>

    </Grid>
</ContentView>