<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudyMateProject.Components.MatrixInputComponent"
             x:Name="MatrixRoot">

    <!-- Компонент для ввода и отображения матриц -->
    <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
            StrokeThickness="1"
            Padding="12">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="8"/>
        </Border.StrokeShape>

        <Grid RowDefinitions="Auto,Auto,*,Auto">

            <!-- Заголовок матрицы -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,8">

                <Label Grid.Column="0"
                       Text="{Binding MatrixName, Source={x:Reference MatrixRoot}, StringFormat='Матрица {0}'}"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                       VerticalOptions="Center"/>

                <!-- Кнопка настроек размера -->
                <Button Grid.Column="1"
                        Text="📐"
                        Command="{Binding ShowSizeDialogCommand, Source={x:Reference MatrixRoot}}"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource White}"
                        HeightRequest="32"
                        WidthRequest="32"
                        FontSize="16"
                        Margin="4,0"/>

                <!-- Меню действий -->
                <Button Grid.Column="2"
                        Text="⋮"
                        Command="{Binding ShowMatrixMenuCommand, Source={x:Reference MatrixRoot}}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}"
                        HeightRequest="32"
                        WidthRequest="32"
                        FontSize="16"
                        Margin="4,0"/>
            </Grid>

            <!-- Информация о размере матрицы -->
            <Label Grid.Row="1"
                   Text="{Binding MatrixSize, Source={x:Reference MatrixRoot}}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                   Margin="0,0,0,8"/>

            <!-- Сетка ввода элементов матрицы -->
            <ScrollView Grid.Row="2" 
                       Orientation="Both"
                       HorizontalScrollBarVisibility="Always"
                       VerticalScrollBarVisibility="Always">

                <Grid x:Name="MatrixGrid"
                      RowSpacing="4"
                      ColumnSpacing="4"
                      Padding="8"
                      BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">

                    <!-- Элементы матрицы создаются программно -->

                </Grid>
            </ScrollView>

            <!-- Кнопки действий с матрицей -->
            <StackLayout Grid.Row="3" 
                        Orientation="Horizontal" 
                        HorizontalOptions="Center"
                        Spacing="8"
                        Margin="0,8,0,0">

                <Button Text="Очистить"
                        Command="{Binding ClearMatrixCommand, Source={x:Reference MatrixRoot}}"
                        BackgroundColor="{StaticResource Warning}"
                        TextColor="{StaticResource White}"
                        HeightRequest="36"
                        FontSize="12"/>

                <Button Text="Случайные"
                        Command="{Binding FillRandomCommand, Source={x:Reference MatrixRoot}}"
                        BackgroundColor="{StaticResource Info}"
                        TextColor="{StaticResource White}"
                        HeightRequest="36"
                        FontSize="12"/>

                <Button Text="Единичная"
                        Command="{Binding MakeIdentityCommand, Source={x:Reference MatrixRoot}}"
                        BackgroundColor="{StaticResource Success}"
                        TextColor="{StaticResource White}"
                        HeightRequest="36"
                        FontSize="12"
                        IsVisible="{Binding IsSquareMatrix, Source={x:Reference MatrixRoot}}"/>

            </StackLayout>

        </Grid>
    </Border>
</ContentView>