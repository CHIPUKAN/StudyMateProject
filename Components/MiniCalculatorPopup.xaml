<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:StudyMateProject.Components"
             x:Class="StudyMateProject.Components.MiniCalculatorPopup"
             x:Name="MiniCalculatorRoot">

    <!-- Всплывающий мини-калькулятор для заметок -->
    <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
            StrokeThickness="2"
            Opacity="{Binding Opacity}"
            IsVisible="{Binding IsPopupVisible, Source={x:Reference MiniCalculatorRoot}}">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16"/>
        </Border.StrokeShape>

        <!-- Тень для popup эффекта -->
        <Border.Shadow>
            <Shadow Brush="Black" 
                    Opacity="0.3" 
                    Radius="8" 
                    Offset="0,4"/>
        </Border.Shadow>

        <Grid RowDefinitions="Auto,*,Auto" Padding="12">

            <!-- Заголовок с управлением -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,8">

                <Label Grid.Column="0" 
                       Text="Калькулятор"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                       VerticalOptions="Center"/>

                <!-- Кнопка компактного режима -->
                <Button Grid.Column="1"
                        Text="{Binding IsCompactMode, Converter={StaticResource BoolToCompactTextConverter}}"
                        Command="{Binding ToggleCompactCommand}"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource White}"
                        HeightRequest="32"
                        WidthRequest="32"
                        FontSize="12"
                        Margin="4,0"/>

                <!-- Кнопка закрытия -->
                <Button Grid.Column="2"
                        Text="✕"
                        Command="{Binding CloseCommand}"
                        BackgroundColor="{StaticResource Danger}"
                        TextColor="{StaticResource White}"
                        HeightRequest="32"
                        WidthRequest="32"
                        FontSize="16"
                        Margin="4,0"/>
            </Grid>

            <!-- Основной калькулятор -->
            <components:CalculatorComponent Grid.Row="1"
                                          BindingContext="{Binding}"
                                          IsMiniMode="True"
                                          FontSize="18"
                                          ShowInsertButton="{Binding ShowInsertButton}"
                                          ShowExpandButton="{Binding ShowExpandButton}"/>

            <!-- Нижняя панель с дополнительными действиями -->
            <StackLayout Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalOptions="Center"
                        Spacing="8"
                        Margin="0,8,0,0"
                        IsVisible="{Binding IsCompactMode, Converter={StaticResource InverseBoolConverter}}">

                <!-- Быстрые действия -->
                <Button Text="📋" 
                        Command="{Binding InsertResultCommand}"
                        BackgroundColor="{StaticResource Info}"
                        TextColor="{StaticResource White}"
                        HeightRequest="36"
                        WidthRequest="36"
                        FontSize="16"
                        IsVisible="{Binding ShowInsertButton}"/>

                <Button Text="📄" 
                        Command="{Binding CopyResultCommand}"
                        BackgroundColor="{StaticResource Info}"
                        TextColor="{StaticResource White}"
                        HeightRequest="36"
                        WidthRequest="36"
                        FontSize="16"/>

                <Button Text="🔍" 
                        Command="{Binding ExpandToFullCommand}"
                        BackgroundColor="{StaticResource Info}"
                        TextColor="{StaticResource White}"
                        HeightRequest="36"
                        WidthRequest="36"
                        FontSize="16"
                        IsVisible="{Binding ShowExpandButton}"/>

                <Button Text="⚙️" 
                        Command="{Binding ShowSettingsCommand}"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource White}"
                        HeightRequest="36"
                        WidthRequest="36"
                        FontSize="16"/>

            </StackLayout>

        </Grid>

    </Border>
</ContentView>