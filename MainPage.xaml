<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StudyMateProject.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="StudyMate - Главная"
             BackgroundColor="#F8F9FA">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">

            <!-- Приветствие -->
            <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True" Padding="15" Margin="10,5">
                <StackLayout>
                    <Label Text="🧮 Добро пожаловать в StudyMate Calculator!" 
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#212529"
                           Margin="0,10,0,5"
                           HorizontalOptions="Center" />
                    <Label Text="Ваш персональный калькулятор для учебы" 
                           FontSize="16"
                           TextColor="#6C757D"
                           HorizontalOptions="Center" />
                </StackLayout>
            </Frame>

            <!-- Быстрые действия -->
            <Label Text="Выберите тип калькулятора" 
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#212529"
                   Margin="0,5,0,5" />

            <Grid RowDefinitions="Auto" ColumnDefinitions="*,*" RowSpacing="15" ColumnSpacing="15">

                <!-- Обычный калькулятор -->
                <Frame Grid.Row="0" Grid.Column="0" BackgroundColor="White" CornerRadius="12" HasShadow="True" Padding="15" Margin="5">
                    <StackLayout>
                        <Label Text="🧮" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Обычный" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Базовые операции" FontSize="12" TextColor="#6C757D" HorizontalOptions="Center" />
                        <Button Text="Открыть" 
                                BackgroundColor="#2E8B57"
                                TextColor="White"
                                FontSize="14"
                                Padding="15,8"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                Clicked="OnCalculatorClicked"
                                Margin="0,10,0,0" />
                    </StackLayout>
                </Frame>

                <!-- Научный калькулятор -->
                <Frame Grid.Row="0" Grid.Column="1" BackgroundColor="White" CornerRadius="12" HasShadow="True" Padding="15" Margin="5">
                    <StackLayout>
                        <Label Text="🔬" FontSize="40" HorizontalOptions="Center" />
                        <Label Text="Научный" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Все функции" FontSize="12" TextColor="#6C757D" HorizontalOptions="Center" />
                        <Button Text="Открыть" 
                                BackgroundColor="#6A5ACD"
                                TextColor="White"
                                FontSize="14"
                                Padding="15,8"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                Clicked="OnScientificCalculatorClicked"
                                Margin="0,10,0,0" />
                    </StackLayout>
                </Frame>

            </Grid>

            <!-- Возможности обычного калькулятора -->
            <Label Text="Обычный калькулятор" 
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#212529"
                   Margin="0,15,0,5" />

            <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True" Padding="15" Margin="10,5">
                <StackLayout Spacing="10">
                    <Label Text="✅ Базовые операции (+, -, ×, ÷)" FontSize="14" />
                    <Label Text="✅ Скобки для группировки" FontSize="14" />
                    <Label Text="✅ Квадратный корень (√)" FontSize="14" />
                    <Label Text="✅ Работа с десятичными числами" FontSize="14" />
                    <Label Text="✅ Проценты (%)" FontSize="14" />
                </StackLayout>
            </Frame>

            <!-- Возможности научного калькулятора -->
            <Label Text="Научный калькулятор" 
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#212529"
                   Margin="0,15,0,5" />

            <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True" Padding="15" Margin="10,5">
                <StackLayout Spacing="10">
                    <Label Text="🔬 Тригонометрические функции (sin, cos, tan)" FontSize="14" />
                    <Label Text="🔬 Степенные функции (x², x³, x^y)" FontSize="14" />
                    <Label Text="🔬 Логарифмы (ln)" FontSize="14" />
                    <Label Text="🔬 Константы (π, e)" FontSize="14" />
                    <Label Text="🔬 Все функции обычного калькулятора" FontSize="14" />
                </StackLayout>
            </Frame>

            <!-- Статистика использования -->
            <Label Text="Статистика" 
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#212529"
                   Margin="0,15,0,5" />

            <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True" Padding="15" Margin="10,5">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" RowSpacing="15" ColumnSpacing="15">

                    <StackLayout Grid.Row="0" Grid.Column="0">
                        <Label Text="🧮" FontSize="30" HorizontalOptions="Center" />
                        <Label x:Name="CalculationsCountLabel" Text="0" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Вычислений" FontSize="14" HorizontalOptions="Center" TextColor="#6C757D" />
                    </StackLayout>

                    <StackLayout Grid.Row="0" Grid.Column="1">
                        <Label Text="📊" FontSize="30" HorizontalOptions="Center" />
                        <Label x:Name="SessionTimeLabel" Text="0 мин" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Время сессии" FontSize="14" HorizontalOptions="Center" TextColor="#6C757D" />
                    </StackLayout>

                    <!-- Последнее вычисление -->
                    <StackLayout Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0">
                        <Label Text="Последнее вычисление:" FontSize="16" FontAttributes="Bold" />
                        <Label x:Name="LastCalculationLabel" 
                               Text="Пока нет вычислений" 
                               FontSize="14" 
                               TextColor="#6C757D"
                               FontFamily="Consolas" />
                    </StackLayout>

                </Grid>
            </Frame>

            <!-- Советы по использованию -->
            <Label Text="Совет дня" 
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#212529"
                   Margin="0,15,0,5" />

            <Frame BackgroundColor="#2E8B57" CornerRadius="12" HasShadow="True" Padding="15" Margin="10,5">
                <StackLayout>
                    <Label Text="💡" FontSize="30" HorizontalOptions="Center" />
                    <Label x:Name="TipOfDayLabel" 
                           Text="Используйте скобки для сложных вычислений: (2+3)×4 = 20"
                           FontSize="16"
                           TextColor="White"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </StackLayout>
            </Frame>

        </StackLayout>
    </ScrollView>

</ContentPage>