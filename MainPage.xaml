<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudyMateProject.MainPage"
             Title="StudyMate">

    <Grid>
        <!-- Точная копия градиента с картинки -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#A8D8EA" Offset="0.0" />
                <GradientStop Color="#C7E9F1" Offset="0.2" />
                <GradientStop Color="#E8F6FF" Offset="0.5" />
                <GradientStop Color="#F7E7F3" Offset="0.7" />
                <GradientStop Color="#F4C2C2" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <StackLayout Padding="30" Spacing="25">

                <!-- Заголовок -->
                <StackLayout HorizontalOptions="Center" Spacing="15">
                    <Label Text="StudyMate" 
                           FontSize="{OnPlatform iOS=48, Android=44, WinUI=52}" 
                           FontFamily="Georgia"
                           FontAttributes="Bold"
                           TextColor="#1B4A5C"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0" />

                    <Label Text="SM — ПОВОД СХОДИТЬ НА ПАРЫ!" 
                           FontSize="{OnPlatform iOS=24, Android=22, WinUI=26}" 
                           FontFamily="Arial"
                           FontAttributes="Bold"
                           TextColor="#A23B72"
                           HorizontalOptions="Center"
                           Margin="0,0,0,10" />
                </StackLayout>

                <!-- Основные функции -->
                <StackLayout Spacing="20" Margin="0,40,0,0">

                    <!-- Кнопка "Мои тетради" -->
                    <Frame BackgroundColor="White" 
                           CornerRadius="20"
                           HasShadow="True"
                           Padding="0"
                           HeightRequest="{OnPlatform iOS=85, Android=80, WinUI=90}">
                        <Button Text="📚 Мои тетради"
                                BackgroundColor="Transparent"
                                TextColor="#2E86AB"
                                FontSize="{OnPlatform iOS=26, Android=24, WinUI=23}"
                                FontFamily="Arial"
                                FontAttributes="Bold"
                                Clicked="OnNotebooksClicked" />
                    </Frame>

                    <!-- Кнопка "Мои напоминания" -->
                    <Frame BackgroundColor="White" 
                           CornerRadius="20"
                           HasShadow="True"
                           Padding="0"
                           HeightRequest="{OnPlatform iOS=85, Android=80, WinUI=90}">
                        <Button Text="⏰ Мои напоминания"
                                BackgroundColor="Transparent"
                                TextColor="#A23B72"
                                FontSize="{OnPlatform iOS=26, Android=24, WinUI=23}"
                                FontFamily="Arial"
                                FontAttributes="Bold"
                                Clicked="OnRemindersClicked" />
                    </Frame>

                    <!-- Кнопка "Калькулятор" -->
                    <Frame BackgroundColor="White" 
                           CornerRadius="20"
                           HasShadow="True"
                           Padding="0"
                           HeightRequest="{OnPlatform iOS=85, Android=80, WinUI=90}">
                        <Button Text="🔢 Открыть калькулятор"
                                BackgroundColor="Transparent"
                                TextColor="#F18F01"
                                FontSize="{OnPlatform iOS=26, Android=24, WinUI=23}"
                                FontFamily="Arial"
                                FontAttributes="Bold"
                                Clicked="OnCalculatorClicked" />
                    </Frame>

                </StackLayout>

                <!-- Мотивационный текст -->
                <StackLayout Margin="0,50,0,0" HorizontalOptions="Center">
                    <Label Text="Еще сюда че-нибудь пока не знаем" 
                           FontSize="{OnPlatform iOS=20, Android=18, WinUI=22}"
                           FontFamily="Arial"
                           TextColor="Gray"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </StackLayout>

            </StackLayout>
        </ScrollView>
    </Grid>
</ContentPage>