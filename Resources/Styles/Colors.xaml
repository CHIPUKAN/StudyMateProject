<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary Colors -->
    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#ac99ea</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>

    <!-- Secondary Colors -->
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#2dd4bf</Color>

    <!-- Gray Scale -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <!-- Gray Palette -->
    <Color x:Key="Gray100">#F7F7F7</Color>
    <Color x:Key="Gray200">#E1E1E1</Color>
    <Color x:Key="Gray300">#C7C7C7</Color>
    <Color x:Key="Gray400">#9E9E9E</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray700">#303030</Color>
    <Color x:Key="Gray800">#212121</Color>
    <Color x:Key="Gray900">#161616</Color>

    <!-- Calculator Specific Colors -->
    <Color x:Key="CalculatorBackground">#F5F5F5</Color>
    <Color x:Key="CalculatorDisplay">#FFFFFF</Color>
    <Color x:Key="CalculatorButton">#E0E0E0</Color>
    <Color x:Key="CalculatorButtonPressed">#BDBDBD</Color>
    <Color x:Key="CalculatorOperator">#FF9500</Color>
    <Color x:Key="CalculatorOperatorPressed">#FF8000</Color>
    <Color x:Key="CalculatorClear">#FF3B30</Color>
    <Color x:Key="CalculatorEqual">#34C759</Color>

    <!-- Status Colors -->
    <Color x:Key="Success">#28A745</Color>
    <Color x:Key="Warning">#FFC107</Color>
    <Color x:Key="Error">#DC3545</Color>
    <Color x:Key="Info">#17A2B8</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#212121</Color>
    <Color x:Key="TextSecondary">#757575</Color>
    <Color x:Key="TextDisabled">#BDBDBD</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>
    <Color x:Key="TextOnSecondary">#000000</Color>

    <!-- Background Colors -->
    <Color x:Key="BackgroundPrimary">#FFFFFF</Color>
    <Color x:Key="BackgroundSecondary">#F8F9FA</Color>
    <Color x:Key="BackgroundTertiary">#E9ECEF</Color>

    <!-- Dark Theme Colors -->
    <Color x:Key="DarkBackground">#121212</Color>
    <Color x:Key="DarkSurface">#1E1E1E</Color>
    <Color x:Key="DarkOnSurface">#FFFFFF</Color>
    <Color x:Key="DarkOnBackground">#FFFFFF</Color>

</ResourceDictionary>