<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StudyMateProject.Views.ScientificCalculatorPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Научный калькулятор">

    <Grid Padding="10" RowSpacing="5" ColumnSpacing="5">
        <!-- Определяем строки -->
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <!-- Дисплей -->
            <RowDefinition Height="*"/>
            <!-- Строка 1: C, CE, (, ) -->
            <RowDefinition Height="*"/>
            <!-- Строка 2: sin, cos, tan, ln -->
            <RowDefinition Height="*"/>
            <!-- Строка 3: x², x³, x^y, √ -->
            <RowDefinition Height="*"/>
            <!-- Строка 4: 7, 8, 9, ÷ -->
            <RowDefinition Height="*"/>
            <!-- Строка 5: 4, 5, 6, × -->
            <RowDefinition Height="*"/>
            <!-- Строка 6: 1, 2, 3, − -->
            <RowDefinition Height="*"/>
            <!-- Строка 7: 0, ., π, + -->
            <RowDefinition Height="*"/>
            <!-- Строка 8: e, %, =, = -->
        </Grid.RowDefinitions>

        <!-- Определяем колонки -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Дисплей -->
        <Border Grid.Row="0" Grid.ColumnSpan="4" 
                BackgroundColor="Black" 
                Stroke="Gray" 
                StrokeThickness="2">
            <StackLayout Padding="15" VerticalOptions="End">
                <!-- Показываем выражение -->
                <Label x:Name="ExpressionLabel" 
                       Text="0" 
                       TextColor="LightGray" 
                       FontSize="14" 
                       HorizontalOptions="End"/>
                <!-- Показываем результат -->
                <Label x:Name="DisplayLabel" 
                       Text="0" 
                       TextColor="White" 
                       FontSize="28" 
                       FontAttributes="Bold"
                       HorizontalOptions="End"/>
            </StackLayout>
        </Border>

        <!-- Первая строка: C, CE, (, ) -->
        <Button Grid.Row="1" Grid.Column="0" 
                Text="C" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="18"
                Clicked="OnClearClicked"/>

        <Button Grid.Row="1" Grid.Column="1" 
                Text="CE" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="18"
                Clicked="OnClearEntryClicked"/>

        <Button Grid.Row="1" Grid.Column="2" 
                Text="(" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="18"
                Clicked="OnOpenParenthesisClicked"/>

        <Button Grid.Row="1" Grid.Column="3" 
                Text=")" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="18"
                Clicked="OnCloseParenthesisClicked"/>

        <!-- Вторая строка: sin, cos, tan, ln -->
        <Button Grid.Row="2" Grid.Column="0" 
                Text="sin" 
                BackgroundColor="Purple" 
                TextColor="White"
                FontSize="16"
                Clicked="OnScientificFunctionClicked"/>

        <Button Grid.Row="2" Grid.Column="1" 
                Text="cos" 
                BackgroundColor="Purple" 
                TextColor="White"
                FontSize="16"
                Clicked="OnScientificFunctionClicked"/>

        <Button Grid.Row="2" Grid.Column="2" 
                Text="tan" 
                BackgroundColor="Purple" 
                TextColor="White"
                FontSize="16"
                Clicked="OnScientificFunctionClicked"/>

        <Button Grid.Row="2" Grid.Column="3" 
                Text="ln" 
                BackgroundColor="Purple" 
                TextColor="White"
                FontSize="16"
                Clicked="OnScientificFunctionClicked"/>

        <!-- Третья строка: x², x³, x^y, √ -->
        <Button Grid.Row="3" Grid.Column="0" 
                Text="x²" 
                BackgroundColor="Purple" 
                TextColor="White"
                FontSize="16"
                Clicked="OnPowerClicked"/>

        <Button Grid.Row="3" Grid.Column="1" 
                Text="x³" 
                BackgroundColor="Purple" 
                TextColor="White"
                FontSize="16"
                Clicked="OnCubeClicked"/>

        <Button Grid.Row="3" Grid.Column="2" 
                Text="x^y" 
                BackgroundColor="Purple" 
                TextColor="White"
                FontSize="16"
                Clicked="OnPowerYClicked"/>

        <Button Grid.Row="3" Grid.Column="3" 
                Text="√" 
                BackgroundColor="Purple" 
                TextColor="White"
                FontSize="18"
                Clicked="OnSquareRootClicked"/>

        <!-- Четвертая строка: 7, 8, 9, ÷ -->
        <Button Grid.Row="4" Grid.Column="0" 
                Text="7" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="20"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="4" Grid.Column="1" 
                Text="8" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="20"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="4" Grid.Column="2" 
                Text="9" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="20"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="4" Grid.Column="3" 
                Text="÷" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="18"
                Clicked="OnOperatorClicked"/>

        <!-- Пятая строка: 4, 5, 6, × -->
        <Button Grid.Row="5" Grid.Column="0" 
                Text="4" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="20"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="5" Grid.Column="1" 
                Text="5" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="20"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="5" Grid.Column="2" 
                Text="6" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="20"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="5" Grid.Column="3" 
                Text="×" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="18"
                Clicked="OnOperatorClicked"/>

        <!-- Шестая строка: 1, 2, 3, − -->
        <Button Grid.Row="6" Grid.Column="0" 
                Text="1" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="20"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="6" Grid.Column="1" 
                Text="2" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="20"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="6" Grid.Column="2" 
                Text="3" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="20"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="6" Grid.Column="3" 
                Text="−" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="18"
                Clicked="OnOperatorClicked"/>

        <!-- Седьмая строка: 0, ., π, + -->
        <Button Grid.Row="7" Grid.Column="0" 
                Text="0" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="20"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="7" Grid.Column="1" 
                Text="." 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="20"
                Clicked="OnDecimalClicked"/>

        <Button Grid.Row="7" Grid.Column="2" 
                Text="π" 
                BackgroundColor="Purple" 
                TextColor="White"
                FontSize="18"
                Clicked="OnPiClicked"/>

        <Button Grid.Row="7" Grid.Column="3" 
                Text="+" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="18"
                Clicked="OnOperatorClicked"/>

        <!-- Восьмая строка: e, %, =, = -->
        <Button Grid.Row="8" Grid.Column="0" 
                Text="e" 
                BackgroundColor="Purple" 
                TextColor="White"
                FontSize="18"
                Clicked="OnEulerClicked"/>

        <Button Grid.Row="8" Grid.Column="1" 
                Text="%" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="18"
                Clicked="OnOperatorClicked"/>

        <Button Grid.Row="8" Grid.ColumnSpan="2" Grid.Column="2" 
                Text="=" 
                BackgroundColor="DodgerBlue" 
                TextColor="White"
                FontSize="18"
                Clicked="OnEqualsClicked"/>

    </Grid>
</ContentPage>