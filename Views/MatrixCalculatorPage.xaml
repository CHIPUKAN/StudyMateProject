<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:StudyMateProject.Components"
             xmlns:viewmodels="clr-namespace:StudyMateProject.ViewModels"
             x:Class="StudyMateProject.Views.MatrixCalculatorPage"
             x:DataType="viewmodels:MatrixCalculatorViewModel"
             Title="Калькулятор матриц"
             Shell.NavBarIsVisible="True">

    <!-- Страница для работы с матрицами -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Верхняя панель с операциями -->
        <Border Grid.Row="0" 
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
                Padding="16,12">

            <Grid ColumnDefinitions="*,Auto,Auto">

                <!-- Выбор операции -->
                <Picker Grid.Column="0"
                        ItemsSource="{Binding AvailableOperations}"
                        SelectedItem="{Binding SelectedOperation}"
                        FontSize="16"
                        TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray700}}"
                        HorizontalOptions="FillAndExpand"
                        VerticalOptions="Center"/>

                <!-- Поле для скаляра -->
                <Entry Grid.Column="1"
                       Text="{Binding ScalarValue}"
                       Placeholder="Скаляр"
                       Keyboard="Numeric"
                       WidthRequest="80"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding SelectedOperation, Converter={StaticResource OperationToScalarVisibilityConverter}}"
                       Margin="8,0"/>

                <!-- Кнопка выполнения операции -->
                <Button Grid.Column="2"
                        Text="Вычислить"
                        Command="{Binding PerformOperationCommand}"
                        BackgroundColor="{StaticResource Success}"
                        TextColor="{StaticResource White}"
                        FontSize="14"
                        HeightRequest="40"
                        WidthRequest="100"/>

            </Grid>
        </Border>

        <!-- Основной контент -->
        <ScrollView Grid.Row="1" Orientation="Both">
            <Grid ColumnDefinitions="*,*,*" 
                  RowDefinitions="Auto,*,Auto,*"
                  Padding="16"
                  ColumnSpacing="16"
                  RowSpacing="16">

                <!-- Заголовки матриц -->
                <Label Grid.Row="0" Grid.Column="0"
                       Text="Матрица A"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                       HorizontalOptions="Center"/>

                <Label Grid.Row="0" Grid.Column="1"
                       Text="Операция"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                       HorizontalOptions="Center"/>

                <Label Grid.Row="0" Grid.Column="2"
                       Text="Матрица B"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                       HorizontalOptions="Center"/>

                <!-- Матрица A -->
                <components:MatrixInputComponent Grid.Row="1" Grid.Column="0"
                                               Matrix="{Binding MatrixA}"
                                               MatrixName="A"
                                               CellSize="50"/>

                <!-- Панель операций -->
                <StackLayout Grid.Row="1" Grid.Column="1"
                            Spacing="12"
                            VerticalOptions="Center"
                            HorizontalOptions="Center">

                    <!-- Операции с двумя матрицами -->
                    <Button Text="A + B"
                            Command="{Binding AddMatricesCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="40"
                            WidthRequest="80"
                            FontSize="14"/>

                    <Button Text="A - B"
                            Command="{Binding SubtractMatricesCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="40"
                            WidthRequest="80"
                            FontSize="14"/>

                    <Button Text="A × B"
                            Command="{Binding MultiplyMatricesCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="40"
                            WidthRequest="80"
                            FontSize="14"/>

                    <!-- Операции с одной матрицей -->
                    <Rectangle Fill="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                              HeightRequest="1"
                              Margin="0,8"/>

                    <Button Text="Aᵀ"
                            Command="{Binding TransposeACommand}"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="40"
                            WidthRequest="80"
                            FontSize="14"/>

                    <Button Text="A⁻¹"
                            Command="{Binding InverseACommand}"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="40"
                            WidthRequest="80"
                            FontSize="14"/>

                    <Button Text="det(A)"
                            Command="{Binding DeterminantACommand}"
                            BackgroundColor="{StaticResource Tertiary}"
                            TextColor="{StaticResource White}"
                            HeightRequest="40"
                            WidthRequest="80"
                            FontSize="12"/>

                </StackLayout>

                <!-- Матрица B -->
                <components:MatrixInputComponent Grid.Row="1" Grid.Column="2"
                                               Matrix="{Binding MatrixB}"
                                               MatrixName="B"
                                               CellSize="50"/>

                <!-- Заголовок результата -->
                <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                       Text="Результат"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                       HorizontalOptions="Center"
                       Margin="0,16,0,0"/>

                <!-- Область результата -->
                <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray850}}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                        StrokeThickness="1"
                        HeightRequest="150"
                        Padding="16">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>

                    <ScrollView Orientation="Both">
                        <StackLayout Spacing="12">

                            <!-- Текстовый результат -->
                            <Label Text="{Binding OperationResult}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                                   HorizontalOptions="Center"
                                   IsVisible="{Binding OperationResult, Converter={StaticResource IsStringNotNullOrEmptyConverter}}"/>

                            <!-- Матричный результат -->
                            <Grid x:Name="ResultMatrixGrid"
                                  IsVisible="{Binding ResultMatrix, Converter={StaticResource IsNotNullConverter}}"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center"
                                  RowSpacing="4"
                                  ColumnSpacing="4">

                                <!-- Элементы результата создаются в code-behind -->

                            </Grid>

                            <!-- Детали операции -->
                            <Label Text="{Binding OperationDetails}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                   HorizontalOptions="Start"
                                   IsVisible="{Binding OperationDetails, Converter={StaticResource IsStringNotNullOrEmptyConverter}}"
                                   LineBreakMode="WordWrap"/>

                            <!-- Индикатор вычислений -->
                            <StackLayout Orientation="Horizontal"
                                        HorizontalOptions="Center"
                                        Spacing="8"
                                        IsVisible="{Binding IsCalculating}">
                                <ActivityIndicator IsRunning="{Binding IsCalculating}"
                                                  Color="{StaticResource Primary}"
                                                  HeightRequest="24"/>
                                <Label Text="{Binding StatusMessage}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                       VerticalOptions="Center"/>
                            </StackLayout>

                            <!-- Сообщение об ошибке -->
                            <Border IsVisible="{Binding HasError}"
                                   BackgroundColor="{StaticResource DangerLight}"
                                   Stroke="{StaticResource Danger}"
                                   StrokeThickness="1"
                                   Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="4"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding ErrorMessage}"
                                       TextColor="{StaticResource Danger}"
                                       FontSize="12"
                                       LineBreakMode="WordWrap"/>
                            </Border>

                        </StackLayout>
                    </ScrollView>
                </Border>

            </Grid>
        </ScrollView>

        <!-- Нижняя панель с дополнительными действиями -->
        <Border Grid.Row="2"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
                Padding="16,8">

            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">

                <!-- Статус -->
                <Label Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                       VerticalOptions="Center"/>

                <!-- Кнопки действий -->
                <Button Grid.Column="1"
                        Text="📋"
                        Command="{Binding CopyResultCommand}"
                        BackgroundColor="{StaticResource Info}"
                        TextColor="{StaticResource White}"
                        HeightRequest="36"
                        WidthRequest="36"
                        FontSize="16"
                        Margin="4,0"/>

                <Button Grid.Column="2"
                        Text="📤"
                        Command="{Binding ExportResultCommand}"
                        BackgroundColor="{StaticResource Info}"
                        TextColor="{StaticResource White}"
                        HeightRequest="36"
                        WidthRequest="36"
                        FontSize="16"
                        Margin="4,0"/>

               

                <Button Grid.Column="4"
                        Text="🗑️"
                        Command="{Binding ClearHistoryCommand}"
                        BackgroundColor="{StaticResource Warning}"
                        TextColor="{StaticResource White}"
                        HeightRequest="36"
                        WidthRequest="36"
                        FontSize="16"
                        Margin="4,0"/>

            </Grid>
        </Border>

    </Grid>
</ContentPage>