<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StudyMateProject.Views.CalculatorPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Калькулятор">

    <Grid Padding="10" RowSpacing="5" ColumnSpacing="5">
        <!-- Определяем строки -->
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <!-- Дисплей -->
            <RowDefinition Height="*"/>
            <!-- Строка 1: C, CE, %, / -->
            <RowDefinition Height="*"/>
            <!-- Строка 2: 7, 8, 9, * -->
            <RowDefinition Height="*"/>
            <!-- Строка 3: 4, 5, 6, - -->
            <RowDefinition Height="*"/>
            <!-- Строка 4: 1, 2, 3, + -->
            <RowDefinition Height="*"/>
            <!-- Строка 5: 0, ., √, = -->
        </Grid.RowDefinitions>

        <!-- Определяем колонки -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Дисплей -->
        <Border Grid.Row="0" Grid.ColumnSpan="4" 
                BackgroundColor="Black" 
                Stroke="Gray" 
                StrokeThickness="2">
            <StackLayout Padding="15" VerticalOptions="End">
                <!-- Показываем выражение -->
                <Label x:Name="ExpressionLabel" 
                       Text="0" 
                       TextColor="LightGray" 
                       FontSize="16" 
                       HorizontalOptions="End"/>
                <!-- Показываем результат -->
                <Label x:Name="DisplayLabel" 
                       Text="0" 
                       TextColor="White" 
                       FontSize="32" 
                       FontAttributes="Bold"
                       HorizontalOptions="End"/>
            </StackLayout>
        </Border>

        <!-- Первая строка кнопок: C, CE, %, / -->
        <Button Grid.Row="1" Grid.Column="0" 
                Text="C" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="20"
                Clicked="OnClearClicked"/>

        <Button Grid.Row="1" Grid.Column="1" 
                Text="CE" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="20"
                Clicked="OnClearEntryClicked"/>

        <Button Grid.Row="1" Grid.Column="2" 
                Text="%" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="20"
                Clicked="OnOperatorClicked"/>

        <Button Grid.Row="1" Grid.Column="3" 
                Text="÷" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="20"
                Clicked="OnOperatorClicked"/>

        <!-- Вторая строка кнопок: 7, 8, 9, * -->
        <Button Grid.Row="2" Grid.Column="0" 
                Text="7" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="24"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="2" Grid.Column="1" 
                Text="8" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="24"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="2" Grid.Column="2" 
                Text="9" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="24"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="2" Grid.Column="3" 
                Text="×" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="20"
                Clicked="OnOperatorClicked"/>

        <!-- Третья строка кнопок: 4, 5, 6, - -->
        <Button Grid.Row="3" Grid.Column="0" 
                Text="4" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="24"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="3" Grid.Column="1" 
                Text="5" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="24"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="3" Grid.Column="2" 
                Text="6" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="24"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="3" Grid.Column="3" 
                Text="−" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="20"
                Clicked="OnOperatorClicked"/>

        <!-- Четвертая строка кнопок: 1, 2, 3, + -->
        <Button Grid.Row="4" Grid.Column="0" 
                Text="1" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="24"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="4" Grid.Column="1" 
                Text="2" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="24"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="4" Grid.Column="2" 
                Text="3" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="24"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="4" Grid.Column="3" 
                Text="+" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="20"
                Clicked="OnOperatorClicked"/>

        <!-- Пятая строка кнопок: 0, ., √, = -->
        <Button Grid.Row="5" Grid.Column="0" 
                Text="0" 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="24"
                Clicked="OnNumberClicked"/>

        <Button Grid.Row="5" Grid.Column="1" 
                Text="." 
                BackgroundColor="DarkGray" 
                TextColor="White"
                FontSize="24"
                Clicked="OnDecimalClicked"/>

        <Button Grid.Row="5" Grid.Column="2" 
                Text="√" 
                BackgroundColor="Orange" 
                TextColor="White"
                FontSize="20"
                Clicked="OnSquareRootClicked"/>

        <Button Grid.Row="5" Grid.Column="3" 
                Text="=" 
                BackgroundColor="DodgerBlue" 
                TextColor="White"
                FontSize="20"
                Clicked="OnEqualsClicked"/>

    </Grid>
</ContentPage>