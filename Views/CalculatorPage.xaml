<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StudyMateProject.Views.CalculatorPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Калькулятор"
             BackgroundColor="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="6*" />
        </Grid.RowDefinitions>

        <!-- Дисплей -->
        <StackLayout Grid.Row="0" 
                     Padding="20"
                     VerticalOptions="End">

            <!-- Верхняя строка - статус -->
            <Label x:Name="ExpressionLabel"
                   Text="Введите выражение"
                   FontSize="16"
                   TextColor="Gray"
                   HorizontalTextAlignment="End"
                   VerticalOptions="Start" />

            <!-- Основной дисплей -->
            <Label x:Name="DisplayLabel"
                   Text="0"
                   FontSize="48"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="End"
                   VerticalOptions="End"
                   LineBreakMode="TailTruncation" />
        </StackLayout>

        <!-- Кнопки -->
        <Grid Grid.Row="1" 
              Padding="10"
              RowSpacing="8"
              ColumnSpacing="8">

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Первая строка: C, CE, ⌫, ÷ -->
            <Button Text="C" 
                    Grid.Row="0" Grid.Column="0"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="24"
                    FontAttributes="Bold"
                    Clicked="OnClearClicked" />

            <Button Text="CE" 
                    Grid.Row="0" Grid.Column="1"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="20"
                    FontAttributes="Bold"
                    Clicked="OnClearEntryClicked" />

            <Button Text="⌫" 
                    Grid.Row="0" Grid.Column="2"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="24"
                    FontAttributes="Bold"
                    Clicked="OnBackspaceClicked" />

            <Button Text="÷" 
                    Grid.Row="0" Grid.Column="3"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="28"
                    FontAttributes="Bold"
                    Clicked="OnOperatorClicked" />

            <!-- Вторая строка: √, (, ), × -->
            <Button Text="√" 
                    Grid.Row="1" Grid.Column="0"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="24"
                    FontAttributes="Bold"
                    Clicked="OnSquareRootClicked" />

            <Button Text="(" 
                    Grid.Row="1" Grid.Column="1"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="24"
                    FontAttributes="Bold"
                    Clicked="OnOpenParenthesisClicked" />

            <Button Text=")" 
                    Grid.Row="1" Grid.Column="2"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="24"
                    FontAttributes="Bold"
                    Clicked="OnCloseParenthesisClicked" />

            <Button Text="×" 
                    Grid.Row="1" Grid.Column="3"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="28"
                    FontAttributes="Bold"
                    Clicked="OnOperatorClicked" />

            <!-- Третья строка: 7, 8, 9, − -->
            <Button Text="7" 
                    Grid.Row="2" Grid.Column="0"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="8" 
                    Grid.Row="2" Grid.Column="1"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="9" 
                    Grid.Row="2" Grid.Column="2"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="−" 
                    Grid.Row="2" Grid.Column="3"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnOperatorClicked" />

            <!-- Четвертая строка: 4, 5, 6, + -->
            <Button Text="4" 
                    Grid.Row="3" Grid.Column="0"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="5" 
                    Grid.Row="3" Grid.Column="1"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="6" 
                    Grid.Row="3" Grid.Column="2"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="+" 
                    Grid.Row="3" Grid.Column="3"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnOperatorClicked" />

            <!-- Пятая строка: 1, 2, 3, = -->
            <Button Text="1" 
                    Grid.Row="4" Grid.Column="0"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="2" 
                    Grid.Row="4" Grid.Column="1"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="3" 
                    Grid.Row="4" Grid.Column="2"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="=" 
                    Grid.Row="4" Grid.Column="3"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnEqualsClicked" />

            <!-- Шестая строка: 0 (широкая), ., % -->
            <Button Text="0" 
                    Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="." 
                    Grid.Row="5" Grid.Column="2"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnDecimalClicked" />

            <Button Text="%" 
                    Grid.Row="5" Grid.Column="3"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="24"
                    FontAttributes="Bold"
                    Clicked="OnPercentClicked" />
        </Grid>
    </Grid>
</ContentPage>