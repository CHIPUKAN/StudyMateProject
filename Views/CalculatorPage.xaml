<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StudyMateProject.Views.CalculatorPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Калькулятор"
             BackgroundColor="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="6*" />
        </Grid.RowDefinitions>

        <!-- Дисплей -->
        <StackLayout Grid.Row="0" 
                     BackgroundColor="Black"
                     Padding="20"
                     VerticalOptions="End">

            <!-- Верхняя строка - статус -->
            <Label x:Name="ExpressionLabel"
                   Text="Введите выражение"
                   FontSize="16"
                   TextColor="Gray"
                   HorizontalTextAlignment="End"
                   VerticalOptions="Start" />

            <!-- Основной дисплей -->
            <Label x:Name="DisplayLabel"
                   Text="0"
                   FontSize="48"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="End"
                   VerticalOptions="End"
                   LineBreakMode="TailTruncation" />
        </StackLayout>

        <!-- Кнопки -->
        <!-- ОБЫЧНЫЙ КАЛЬКУЛЯТОР - Панель кнопок -->
        <Grid x:Name="BasicCalculatorPanel"
              Grid.Row="1" 
              BackgroundColor="Black"
              Padding="15"
              RowSpacing="12"
              ColumnSpacing="12"
              IsVisible="True">

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Первая строка: C, CE, ⌫, ÷ -->
            <Button Text="C" 
                    Grid.Row="0" Grid.Column="0"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="24"
                    FontAttributes="Bold"
                    Clicked="OnClearClicked" />

            <Button Text="CE" 
                    Grid.Row="0" Grid.Column="1"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="20"
                    FontAttributes="Bold"
                    Clicked="OnClearEntryClicked" />

            <Button Text="%" 
                    Grid.Row="0" Grid.Column="2"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="24"
                    FontAttributes="Bold"
                    Clicked="OnPercentClicked" />

            <Button Text="⌫" 
                    Grid.Row="0" Grid.Column="3"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="24"
                    FontAttributes="Bold"
                    Clicked="OnBackspaceClicked" />

            <!-- Вторая строка: √, (, ), × -->
            <Button Text="√" 
                    Grid.Row="1" Grid.Column="0"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="24"
                    FontAttributes="Bold"
                    Clicked="OnSquareRootClicked" />

            <Button Text="(" 
                    Grid.Row="1" Grid.Column="1"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="24"
                    FontAttributes="Bold"
                    Clicked="OnOpenParenthesisClicked" />

            <Button Text=")" 
                    Grid.Row="1" Grid.Column="2"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="24"
                    FontAttributes="Bold"
                    Clicked="OnCloseParenthesisClicked" />
            <Button Text="÷" 
                    Grid.Row="1" Grid.Column="3"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="28"
                    FontAttributes="Bold"
                    Clicked="OnOperatorClicked" />

            <!-- Третья строка: 7, 8, 9, − -->
            <Button Text="7" 
                    Grid.Row="2" Grid.Column="0"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="8" 
                    Grid.Row="2" Grid.Column="1"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="9" 
                    Grid.Row="2" Grid.Column="2"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="×" 
                    Grid.Row="2" Grid.Column="3"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="28"
                    FontAttributes="Bold"
                    Clicked="OnOperatorClicked" />

            <!-- Четвертая строка: 4, 5, 6, + -->
            <Button Text="4" 
                    Grid.Row="3" Grid.Column="0"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="5" 
                    Grid.Row="3" Grid.Column="1"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="6" 
                    Grid.Row="3" Grid.Column="2"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="−" 
                    Grid.Row="3" Grid.Column="3"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnOperatorClicked" />

            <!-- Пятая строка: 1, 2, 3, = -->
            <Button Text="1" 
                    Grid.Row="4" Grid.Column="0"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="2" 
                    Grid.Row="4" Grid.Column="1"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="3" 
                    Grid.Row="4" Grid.Column="2"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="+" 
                    Grid.Row="4" Grid.Column="3"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnOperatorClicked" />

            <!-- Шестая строка: 📊, 0, ., % -->
            <Button x:Name="CalculatorModeButton"
                    Grid.Row="5" Grid.Column="0"
                    BackgroundColor="#333333"
                    Padding="1"
                    Clicked="OnToggleCalculatorModeClicked">
                <Button.ImageSource>
                    <FileImageSource File="calc4.png" />
                </Button.ImageSource>
            </Button>
            <Button Text="0" 
                    Grid.Row="5" Grid.Column="1" 
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnNumberClicked" />

            <Button Text="." 
                    Grid.Row="5" Grid.Column="2"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnDecimalClicked" />
            <Button Text="=" 
                    Grid.Row="5" Grid.Column="3"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="32"
                    FontAttributes="Bold"
                    Clicked="OnEqualsClicked" />
        </Grid>

        <!-- НАУЧНЫЙ КАЛЬКУЛЯТОР - Панель кнопок (скрыта по умолчанию) -->
        <Grid x:Name="ScientificCalculatorPanel"
              Grid.Row="1" 
              BackgroundColor="Black"
              Padding="10"
              RowSpacing="8"
              ColumnSpacing="8"
              IsVisible="False">

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Первая строка: sin, cos, tan, cot, ln, log -->
            <Button Text="sin" 
                    Grid.Row="0" Grid.Column="0"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnSinClicked" />

            <Button Text="cos" 
                    Grid.Row="0" Grid.Column="1"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnCosClicked" />

            <Button Text="tan" 
                    Grid.Row="0" Grid.Column="2"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnTanClicked" />

            <Button Text="cot" 
                    Grid.Row="0" Grid.Column="3"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnCotClicked" />

            <Button Text="ln" 
                    Grid.Row="0" Grid.Column="4"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnLnClicked" />

            <Button Text="log" 
                    Grid.Row="0" Grid.Column="5"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnLogClicked" />

            <!-- Вторая строка: (, ), √, x², x³, x^y -->
            <Button Text="(" 
                    Grid.Row="1" Grid.Column="0"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnOpenParenthesisClicked" />

            <Button Text=")" 
                    Grid.Row="1" Grid.Column="1"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnCloseParenthesisClicked" />

            <Button Text="√" 
                    Grid.Row="1" Grid.Column="2"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnSquareRootClicked" />

            <Button Text="x²" 
                    Grid.Row="1" Grid.Column="3"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnSquareClicked" />

            <Button Text="x³" 
                    Grid.Row="1" Grid.Column="4"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnCubeClicked" />

            <Button Text="x^y" 
                    Grid.Row="1" Grid.Column="5"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="12"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnPowerClicked" />

            <!-- Третья строка: π, e, %, C, CE, ⌫ -->
            <Button Text="π" 
                    Grid.Row="2" Grid.Column="0"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnPiClicked" />

            <Button Text="e" 
                    Grid.Row="2" Grid.Column="1"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnEClicked" />

            <Button Text="%" 
                    Grid.Row="2" Grid.Column="2"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    BorderColor="#333333"
                    BorderWidth="1"
                    Clicked="OnPercentClicked" />

            <Button Text="C" 
                    Grid.Row="2" Grid.Column="3"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Clicked="OnClearClicked" />

            <Button Text="CE" 
                    Grid.Row="2" Grid.Column="4"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="14"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Clicked="OnClearEntryClicked" />

            <Button Text="⌫" 
                    Grid.Row="2" Grid.Column="5"
                    BackgroundColor="#A6A6A6"
                    TextColor="Black"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Clicked="OnBackspaceClicked" />

            <!-- Четвертая строка: ÷, ×, −, +, = -->
            <Button Text="÷" 
                    Grid.Row="3" Grid.Column="0"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Clicked="OnOperatorClicked" />

            <Button Text="×" 
                    Grid.Row="3" Grid.Column="1"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Clicked="OnOperatorClicked" />

            <Button Text="−" 
                    Grid.Row="3" Grid.Column="2"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Clicked="OnOperatorClicked" />

            <Button Text="+" 
                    Grid.Row="3" Grid.Column="3"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Clicked="OnOperatorClicked" />

            <Button Text="=" 
                    Grid.Row="3" Grid.Column="4"
                    BackgroundColor="#FF9500"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Clicked="OnEqualsClicked" />

            <!-- Пятая строка: Кнопка возврата в левом нижнем углу -->
            <Button x:Name="CalculatorModeButtonScientific"
                    Text="🔢"
                    Grid.Row="4" Grid.Column="0"
                    BackgroundColor="#666666"
                    TextColor="White"
                    FontSize="20"
                    FontAttributes="Bold"
                    CornerRadius="8"      
                    Clicked="OnToggleCalculatorModeClicked" />
        </Grid>
        <!-- Всплывающее меню выбора калькулятора -->
        <Grid x:Name="CalculatorSelectorOverlay" 
      IsVisible="False"
      BackgroundColor="#80000000"
      Grid.RowSpan="2">

            <Frame BackgroundColor="Black"
           BorderColor="Gray"
           CornerRadius="15"
           Padding="20"
           VerticalOptions="Center"
           HorizontalOptions="Center"
           WidthRequest="280">

                <StackLayout Spacing="15">
                    <!-- Заголовок -->
                    <Label Text="Выберите тип калькулятора"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

                    <!-- Кнопки выбора -->
                    <Button BackgroundColor="#333333"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        HeightRequest="50"
                        Clicked="OnBasicCalculatorSelected">
                        <Button.ImageSource>
                            <FileImageSource File="base.png" />
                        </Button.ImageSource>
                        <Button.Text>Стандартный</Button.Text>
                    </Button>

                    <Button BackgroundColor="#333333"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        HeightRequest="50"
                        Clicked="OnScientificCalculatorSelected">
                        <Button.ImageSource>
                            <FileImageSource File="sqrt1.png" />
                        </Button.ImageSource>
                        <Button.Text>Научный</Button.Text>
                    </Button>

                    <Button Text="❌ Отмена"
                    BackgroundColor="#666666"
                    TextColor="White"
                    FontSize="14"
                    CornerRadius="10"
                    Clicked="OnCancelSelection" />
                </StackLayout>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>