<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:StudyMateProject.Components"
             xmlns:viewmodels="clr-namespace:StudyMateProject.ViewModels"
             x:Class="StudyMateProject.Views.CalculatorPage"
             x:DataType="viewmodels:CalculatorViewModel"
             Title="Калькулятор"
             Shell.NavBarIsVisible="True">

    <!-- Полноэкранная страница калькулятора -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Верхняя панель с переключателями режимов -->
        <Border Grid.Row="0" 
                BackgroundColor="{DynamicResource CalculatorHeaderBackgroundColor}"
                Padding="16,8">

            <Grid ColumnDefinitions="*,Auto,Auto">

                <!-- Переключатель вкладок калькулятора -->
                <ScrollView Grid.Column="0" Orientation="Horizontal">
                    <StackLayout Orientation="Horizontal" Spacing="8">

                        <Button Text="Обычный" 
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="{StaticResource White}"
                                HeightRequest="36"
                                FontSize="14"/>

                        <Button Text="Научный" 
                                BackgroundColor="{StaticResource Secondary}"
                                TextColor="{StaticResource White}"
                                HeightRequest="36"
                                FontSize="14"/>

                        <Button Text="Матрицы" 
                                BackgroundColor="{StaticResource Secondary}"
                                TextColor="{StaticResource White}"
                                HeightRequest="36"
                                FontSize="14"/>

                        <Button Text="Продвинутый" 
                                BackgroundColor="{StaticResource Secondary}"
                                TextColor="{StaticResource White}"
                                HeightRequest="36"
                                FontSize="14"/>

                    </StackLayout>
                </ScrollView>

                <!-- Кнопка настроек -->
                <Button Grid.Column="1"
                        Text="⚙️"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource White}"
                        HeightRequest="36"
                        WidthRequest="36"
                        FontSize="16"
                        Margin="8,0"/>

                <!-- Кнопка истории -->
                <Button Grid.Column="2"
                        Text="📚"
                        Command="{Binding ToggleHistoryCommand}"
                        BackgroundColor="{StaticResource Info}"
                        TextColor="{StaticResource White}"
                        HeightRequest="36"
                        WidthRequest="36"
                        FontSize="16"/>

            </Grid>
        </Border>

        <!-- Основной контент с калькулятором -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto">

            <!-- Основной калькулятор -->
            <components:CalculatorComponent Grid.Column="0"
                                          BindingContext="{Binding}"
                                          IsMiniMode="False"
                                          FontSize="32"/>

            <!-- Боковая панель истории -->
            <Border Grid.Column="1"
                    IsVisible="{Binding ShowHistory}"
                    BackgroundColor="{DynamicResource CalculatorHistoryBackgroundColor}"
                    Stroke="{DynamicResource CalculatorHistoryBorderColor}"
                    StrokeThickness="1"
                    WidthRequest="300"
                    Margin="8,0,0,0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto,*,Auto" Padding="12">

                    <!-- Заголовок истории -->
                    <Label Grid.Row="0"
                           Text="История вычислений"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource CalculatorHistoryTitleColor}"
                           Margin="0,0,0,8"/>

                    <!-- Список истории -->
                    <CollectionView Grid.Row="1"
                                   ItemsSource="{Binding HistoryItems}"
                                   SelectionMode="Single"
                                   >

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid RowDefinitions="Auto,Auto" 
                                      Padding="8,4"
                                      BackgroundColor="Transparent">

                                    <!-- Время -->
                                    <Label Grid.Row="0"
                                           
                                           FontSize="10"
                                           TextColor="{DynamicResource CalculatorHistoryTimeColor}"/>

                                    <!-- Выражение и результат -->
                                    <Label Grid.Row="1"
                                           FontSize="12"
                                           TextColor="{DynamicResource CalculatorHistoryTextColor}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                
                                                      
                                                <Span Text=" = "/>
                                                
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <!-- Жест для повторного использования -->
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CalculatorViewModel}}, Path=InsertFromHistoryCommand}"
                                                             CommandParameter="{Binding}"/>
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Кнопки управления историей -->
                    <StackLayout Grid.Row="2" 
                                Orientation="Horizontal" 
                                HorizontalOptions="Center"
                                Spacing="8"
                                Margin="0,8,0,0">

                        <Button Text="Очистить"
                                Command="{Binding ClearHistoryCommand}"
                                BackgroundColor="{StaticResource Warning}"
                                TextColor="{StaticResource White}"
                                HeightRequest="32"
                                FontSize="12"/>

                        <Button Text="Экспорт"
                                BackgroundColor="{StaticResource Info}"
                                TextColor="{StaticResource White}"
                                HeightRequest="32"
                                FontSize="12"/>

                    </StackLayout>

                </Grid>
            </Border>

        </Grid>

        <!-- Нижняя панель с дополнительной информацией -->
        <Border Grid.Row="2"
                BackgroundColor="{DynamicResource CalculatorFooterBackgroundColor}"
                Padding="16,8"
                >

            <Grid ColumnDefinitions="*,Auto,Auto">

                <!-- Режим углов -->
                <Label Grid.Column="0"
                       Text="{Binding AngleMode, StringFormat='Режим: {0}'}"
                       FontSize="12"
                       TextColor="{DynamicResource CalculatorFooterTextColor}"
                       VerticalOptions="Center"/>

                <!-- Индикатор вычислений -->
                <StackLayout Grid.Column="1" 
                            Orientation="Horizontal" 
                            Spacing="4"
                            IsVisible="{Binding IsCalculating}">
                    <ActivityIndicator IsRunning="{Binding IsCalculating}"
                                      Color="{DynamicResource Primary}"
                                      HeightRequest="16"/>
                    <Label Text="Вычисляется..."
                           FontSize="12"
                           TextColor="{DynamicResource CalculatorFooterTextColor}"
                           VerticalOptions="Center"/>
                </StackLayout>

                <!-- Кнопка копирования результата -->
                <Button Grid.Column="2"
                        Text="📋"
                        Command="{Binding CopyResultCommand}"
                        BackgroundColor="{StaticResource Info}"
                        TextColor="{StaticResource White}"
                        HeightRequest="32"
                        WidthRequest="32"
                        FontSize="16"/>

            </Grid>
        </Border>

    </Grid>
</ContentPage>